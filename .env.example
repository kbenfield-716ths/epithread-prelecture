# Anthropic API key — set in Vercel dashboard, never commit this file with real values
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub personal access token with repo write access (for debrief logging)
GITHUB_TOKEN=your_github_token_here

# GitHub repo where debriefs are stored (format: owner/repo)
GITHUB_DEBRIEF_REPO=your-org/epithread-debriefs

# Branch to write debrief records to
GITHUB_DEBRIEF_BRANCH=main
